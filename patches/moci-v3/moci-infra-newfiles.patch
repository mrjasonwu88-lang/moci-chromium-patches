+// Copyright 2026 安徽魔词信息科技有限公司 (Kuajing168 / MoCi)
+// SPDX-License-Identifier: MIT
+
+#include "chrome/common/moci/fingerprint_config.h"
+
+#include <utility>
+
+#include "base/check.h"
+#include "base/files/file_util.h"
+#include "base/json/json_reader.h"
+#include "base/logging.h"
+#include "base/no_destructor.h"
+
+namespace moci {
+
+namespace {
+
+// Soft cap on JSON file size. The schema is ~166 fields total. A typical
+// serialized config is 8-20 KB. 1 MB is generous; reject anything larger as
+// probably malformed / malicious.
+constexpr size_t kMaxConfigBytes = 1024 * 1024;
+
+}  // namespace
+
+// static
+MoCiFingerprintConfig& MoCiFingerprintConfig::Get() {
+  static base::NoDestructor<MoCiFingerprintConfig> instance;
+  return *instance;
+}
+
+// static
+void MoCiFingerprintConfig::Init(const base::FilePath& json_path) {
+  MoCiFingerprintConfig& self = Get();
+  if (self.init_called_) {
+    LOG(WARNING) << "[MoCi] MoCiFingerprintConfig::Init called twice; "
+                    "ignoring second call. Path=" << json_path.value();
+    return;
+  }
+  self.init_called_ = true;
+
+  if (json_path.empty()) {
+    LOG(INFO) << "[MoCi] no --fingerprint-config provided; farbling disabled";
+    return;
+  }
+
+  std::string contents;
+  if (!base::ReadFileToStringWithMaxSize(json_path, &contents,
+                                         kMaxConfigBytes)) {
+    LOG(ERROR) << "[MoCi] failed to read fingerprint-config from "
+               << json_path.value() << " (missing or >1MB)";
+    return;
+  }
+
+  auto parsed = base::JSONReader::ReadAndReturnValueWithError(
+      contents, base::JSON_PARSE_RFC);
+  if (!parsed.has_value()) {
+    LOG(ERROR) << "[MoCi] JSON parse error in fingerprint-config: "
+               << parsed.error().message << " (line " << parsed.error().line
+               << ", col " << parsed.error().column << ")";
+    return;
+  }
+
+  if (!parsed->is_dict()) {
+    LOG(ERROR) << "[MoCi] fingerprint-config root must be an object, got "
+               << parsed->type();
+    return;
+  }
+
+  self.root_ = std::move(*parsed).TakeDict();
+  self.loaded_ = true;
+  LOG(INFO) << "[MoCi] loaded fingerprint-config from " << json_path.value()
+          << " (" << self.root_.size() << " top-level keys)";
+}
+
+void MoCiFingerprintConfig::LogStatus() const {
+  if (loaded_) {
+    LOG(INFO) << "[MoCi] fingerprint-config active; " << root_.size()
+              << " top-level keys";
+  } else if (init_called_) {
+    LOG(INFO) << "[MoCi] fingerprint-config not loaded (no switch / missing "
+                 "file / parse error); farbling disabled";
+  } else {
+    LOG(WARNING) << "[MoCi] LogStatus called before Init";
+  }
+}
+
+MoCiFingerprintConfig::MoCiFingerprintConfig() = default;
+
+}  // namespace moci

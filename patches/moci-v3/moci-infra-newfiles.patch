+// Copyright 2026 安徽魔词信息科技有限公司 (Kuajing168 / MoCi)
+// SPDX-License-Identifier: MIT
+//
+// MoCi fingerprint configuration singleton.
+//
+// Loaded once per process during PreSandboxStartup from the path given by
+// the --fingerprint-config command line switch (see chrome_switches.h).
+// Subsequent fingerprint farbling patches (Canvas/Audio/WebGL/Font/TLS/...)
+// read configuration via MoCiFingerprintConfig::Get().
+//
+// JSON schema:
+//   https://github.com/mrjasonwu88-lang/moci-chromium-patches/blob/main/docs/fingerprint-config-schema.json
+//
+// Per-environment isolation: each environment in the MoCi client (kuajingke)
+// gets a unique JSON file. Browser process and all child processes (renderer,
+// utility, gpu) share the same file via command line propagation.
+//
+// Thread safety: Init() is called once during process startup. After Init,
+// Get() is read-only and thread-safe.
+
+#ifndef CHROME_COMMON_MOCI_FINGERPRINT_CONFIG_H_
+#define CHROME_COMMON_MOCI_FINGERPRINT_CONFIG_H_
+
+#include <memory>
+#include <string>
+
+#include "base/files/file_path.h"
+#include "base/values.h"
+
+namespace base {
+template <typename T> class NoDestructor;
+}  // namespace base
+
+namespace moci {
+
+class MoCiFingerprintConfig {
+ public:
+  // Returns the process-wide singleton. Always non-null. If Init() was never
+  // called or the JSON file failed to load, returns a singleton with an empty
+  // dictionary (so callers can safely call GetDict() without nullptr checks).
+  static MoCiFingerprintConfig& Get();
+
+  // Initialize from a JSON file path. Called by ChromeMainDelegate in browser
+  // process; called by child process main delegates after they parse the
+  // inherited --fingerprint-config switch. Idempotent: subsequent calls log a
+  // warning and become no-ops.
+  static void Init(const base::FilePath& json_path);
+
+  // Returns the root JSON object as a Dict. Empty Dict if Init() was never
+  // called or the file failed to parse. Never returns nullptr-equivalent.
+  // Callers may safely chain .FindDict("canvas")->FindInt("noiseSeed") etc.
+  const base::DictValue& GetDict() const { return root_; }
+
+  // True if Init() loaded a valid JSON file. False if no --fingerprint-config
+  // was passed, the file was missing, or JSON parse failed. Callers that need
+  // to skip farbling when no config is provided should check this first.
+  bool is_loaded() const { return loaded_; }
+
+  // Log the current load status to stderr. Should be called AFTER InitLogging()
+  // because Init() runs in PreSandboxStartup before the logger is wired up on
+  // Windows — any LOG() emitted during Init() is silently dropped. Call this
+  // from ChromeMainDelegate::SandboxInitialized to surface load state in logs.
+  void LogStatus() const;
+
+  MoCiFingerprintConfig(const MoCiFingerprintConfig&) = delete;
+  MoCiFingerprintConfig& operator=(const MoCiFingerprintConfig&) = delete;
+
+ private:
+  friend class base::NoDestructor<MoCiFingerprintConfig>;
+
+  MoCiFingerprintConfig();
+  ~MoCiFingerprintConfig() = default;
+
+  base::DictValue root_;
+  bool loaded_ = false;
+  bool init_called_ = false;
+};
+
+}  // namespace moci
+
+#endif  // CHROME_COMMON_MOCI_FINGERPRINT_CONFIG_H_

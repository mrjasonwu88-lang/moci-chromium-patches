+#
+# MoCi fingerprint config: loaded from --fingerprint-config JSON in each
+# process during PreSandboxStartup, read by farbling patches across blink
+# renderer / net / components / chrome. Lives in //components so all layers
+# can deps it (vs original location //chrome/common which blink can't see).
+
+component("fingerprint_config") {
+  sources = [
+    "fingerprint_config.h",
+    "fingerprint_config.cc",
+  ]
+
+  defines = [ "IS_MOCI_FINGERPRINT_CONFIG_IMPL" ]
+
+  deps = [ "//base" ]
+}

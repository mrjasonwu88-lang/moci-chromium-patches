 void WindowsTaskbarIconUpdater::UpdateIcon() {
+  // [MoCi Sprint1 任务 3] 如 chrome 启动带 --moci-env-number=N，画数字 overlay
+  // badge (16×16 圆形 dark bg + 白色数字) 让吴总在 Windows 任务栏一眼区分
+  // 多 env chrome 实例。chromium 自带 taskbar::DrawTaskbarDecorationString
+  // 已经实现 skia 渲染，直接复用。
+  auto* cmd = base::CommandLine::ForCurrentProcess();
+  if (cmd && cmd->HasSwitch("moci-env-number")) {
+    std::string num_str = cmd->GetSwitchValueASCII("moci-env-number");
+    int env_num = 0;
+    if (base::StringToInt(num_str, &env_num) && env_num > 0) {
+      taskbar::DrawTaskbarDecorationString(
+          browser_view_->GetNativeWindow(),
+          num_str,
+          "MoCi Env #" + num_str);
+      return;
+    }
+  }
   taskbar::UpdateTaskbarDecoration(browser_view_->browser()->profile(),
                                    browser_view_->GetNativeWindow());
 }

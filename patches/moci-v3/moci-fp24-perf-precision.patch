@@ -20,8 +20,12 @@ class CORE_EXPORT TimeClamper {
   DISALLOW_NEW();
 
  public:
-  static constexpr int kCoarseResolutionMicroseconds = 100;
-  static constexpr int kFineResolutionMicroseconds = 5;
+  // [MoCi fp-24] 10x coarsening for timing-attack / WASM-fingerprint defense:
+  // coarse 100us->1000us (1ms), fine 5us->100us (0.1ms). Cross-origin isolated
+  // origins still get 10x sharper than non-isolated. Defeats WebAssembly compile
+  // timing fingerprints, scroll-jank measurement, Spectre-style probes.
+  static constexpr int kCoarseResolutionMicroseconds = 1000;
+  static constexpr int kFineResolutionMicroseconds = 100;
 
   TimeClamper();
   TimeClamper(const TimeClamper&) = delete;

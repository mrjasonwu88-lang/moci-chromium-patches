diff --git a/build/util/version.py b/build/util/version.py
index c69969b917..9e7adf13fb 100755
--- a/build/util/version.py
+++ b/build/util/version.py
@@ -26,7 +26,9 @@ def FetchValuesFromFile(values_dict, file_name):
 
   The file must exist, otherwise you get the Python exception from open().
   """
-  with open(file_name, 'r') as f:
+  # MoCi: force UTF-8 so BRANDING with Chinese chars (跨境客 / 安徽魔词) doesn't
+  # crash Windows default GBK locale decoding.
+  with open(file_name, 'r', encoding='utf-8') as f:
     for line in f.readlines():
       key, val = line.rstrip('\r\n').split('=', 1)
       values_dict[key] = val
@@ -99,7 +101,9 @@ def SubstFile(file_name, values):
 
   This is like SubstTemplate, except it operates on a file.
   """
-  with open(file_name, 'r') as f:
+  # MoCi: force UTF-8 so substituted Chinese strings (跨境客) don't get
+  # corrupted by Windows default GBK encoding.
+  with open(file_name, 'r', encoding='utf-8') as f:
     template = f.read()
   return SubstTemplate(template, values)
 
@@ -111,16 +115,19 @@ def WriteIfChanged(file_name, contents, mode):
   Does nothing if the contents aren't different than the current contents.
   """
   try:
-    with open(file_name, 'r') as f:
+    # MoCi: UTF-8 read/write so generated .h with Chinese product name
+    # round-trips cleanly. UnicodeDecodeError treated like missing file
+    # (old contents from pre-MoCi build was GBK-encoded, can't decode).
+    with open(file_name, 'r', encoding='utf-8') as f:
       old_contents = f.read()
-  except EnvironmentError:
+  except (EnvironmentError, UnicodeDecodeError):
     pass
   else:
     if contents == old_contents and mode == stat.S_IMODE(
         os.lstat(file_name).st_mode):
       return
     os.unlink(file_name)
-  with open(file_name, 'w') as f:
+  with open(file_name, 'w', encoding='utf-8') as f:
     f.write(contents)
   os.chmod(file_name, mode)
 

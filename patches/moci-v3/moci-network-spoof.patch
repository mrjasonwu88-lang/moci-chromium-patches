+namespace {
+
+// MoCi fp-22: per-env spoof of NetworkInformation (effectiveType / rtt / downlink)
+// pulled from --fingerprint-config path hash so each environment looks like
+// a different network connection.
+bool MoCiNetSpoof(uint64_t* out_seed) {
+  auto* cmd = base::CommandLine::ForCurrentProcess();
+  if (!cmd || !cmd->HasSwitch("fingerprint-config")) return false;
+  auto p = cmd->GetSwitchValuePath("fingerprint-config");
+  if (p.empty()) return false;
+  *out_seed = static_cast<uint64_t>(
+      std::hash<base::FilePath::StringType>{}(p.value()));
+  return true;
+}
+
+}  // namespace

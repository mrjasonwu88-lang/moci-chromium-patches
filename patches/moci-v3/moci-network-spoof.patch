+      V8EffectiveConnectionType::Enum::k4G,
+      V8EffectiveConnectionType::Enum::k4G,
+      V8EffectiveConnectionType::Enum::k3G,
+      V8EffectiveConnectionType::Enum::k4G,
+    };
+    return V8EffectiveConnectionType(kPool[s % std::size(kPool)]);
+  }

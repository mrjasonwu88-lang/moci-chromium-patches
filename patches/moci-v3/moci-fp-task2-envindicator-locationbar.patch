+constexpr int kCopyFeedbackMs = 1500;
+
+// 字段名 / 值 颜色（白卡片配色）
+constexpr SkColor kFieldLabelColor      = SkColorSetRGB(0x64, 0x74, 0x8B);  // slate-500
+constexpr SkColor kFieldValueColor      = SkColorSetRGB(0x0F, 0x17, 0x2A);  // slate-900
+constexpr SkColor kFieldHoverBgColor    = SkColorSetRGB(0xF1, 0xF5, 0xF9);  // slate-100
+constexpr SkColor kRowSeparatorColor    = SkColorSetRGB(0xF1, 0xF5, 0xF9);  // 行底分隔线
+constexpr SkColor kCopiedColor          = SkColorSetRGB(0x05, 0x96, 0x69);  // emerald-600
+constexpr SkColor kCopiedBgColor        = SkColorSetRGB(0xD1, 0xFA, 0xE5);  // emerald-100
+
+gfx::FontList LabelFont() {
+  return gfx::FontList({"Microsoft YaHei UI", "Segoe UI", "Arial"},
+                       gfx::Font::FontStyle::NORMAL, 11,
+                       gfx::Font::Weight::MEDIUM);
+}
+
+gfx::FontList ValueFont() {
+  return gfx::FontList({"Microsoft YaHei UI", "Segoe UI", "Arial"},
+                       gfx::Font::FontStyle::NORMAL, 12,
+                       gfx::Font::Weight::NORMAL);
+}
+
+// 可点击的 row: 水平排版 [label 60px] [value] + hover bg + click 复制
+class CopyableFieldRow : public views::View {
+  METADATA_HEADER(CopyableFieldRow, views::View)
+
+ public:
+  CopyableFieldRow(const std::u16string& label_text,
+                   const std::u16string& value_text,
+                   bool show_bottom_separator)
+      : value_text_(value_text) {
+    auto* layout = SetLayoutManager(std::make_unique<views::BoxLayout>(
+        views::BoxLayout::Orientation::kHorizontal,
+        gfx::Insets::VH(kFieldRowVPad, 6), 8));
+    layout->set_cross_axis_alignment(
+        views::BoxLayout::CrossAxisAlignment::kCenter);
+    if (show_bottom_separator) {
+      // 行底 1px 分隔线
+      SetBorder(views::CreateSolidSidedBorder(
+          gfx::Insets::TLBR(0, 0, 1, 0), kRowSeparatorColor));
+    }
+
+    auto label = std::make_unique<views::Label>(
+        label_text, views::Label::CustomFont{LabelFont()});
+    label->SetEnabledColor(kFieldLabelColor);
+    label->SetBackgroundColor(SK_ColorTRANSPARENT);
+    label->SetHorizontalAlignment(gfx::ALIGN_LEFT);
+    label->SetPreferredSize(gfx::Size(kFieldLabelWidth, kFieldRowHeight - 8));
+    AddChildView(std::move(label));
+
+    auto value = std::make_unique<views::Label>(
+        value_text, views::Label::CustomFont{ValueFont()});
+    value->SetEnabledColor(kFieldValueColor);
+    value->SetBackgroundColor(SK_ColorTRANSPARENT);
+    value->SetHorizontalAlignment(gfx::ALIGN_LEFT);
+    value->SetElideBehavior(gfx::NO_ELIDE);
+    value_label_ = AddChildView(std::move(value));
+    layout->SetFlexForView(value_label_, 1);
+
+    // "✓ 已复制" 浮标 (右侧)，默认隐藏；点击后浮现 1.5s 自动消失
+    auto copied = std::make_unique<views::Label>(
+        u"✓ 已复制",
+        views::Label::CustomFont{
+            gfx::FontList({"Microsoft YaHei UI", "Segoe UI", "Arial"},
+                          gfx::Font::FontStyle::NORMAL, 10,
+                          gfx::Font::Weight::MEDIUM)});
+    copied->SetEnabledColor(kCopiedColor);
+    copied->SetBackgroundColor(kCopiedBgColor);
+    copied->SetHorizontalAlignment(gfx::ALIGN_CENTER);
+    copied->SetBorder(views::CreatePaddedBorder(
+        views::CreateRoundedRectBorder(0, 8, SK_ColorTRANSPARENT),
+        gfx::Insets::VH(1, 6)));
+    copied->SetVisible(false);
+    copied_indicator_ = AddChildView(std::move(copied));
+  }
+
+  bool OnMousePressed(const ui::MouseEvent& event) override {
+    if (!event.IsOnlyLeftMouseButton()) return false;
+    ui::ScopedClipboardWriter writer(ui::ClipboardBuffer::kCopyPaste);
+    writer.WriteText(value_text_);
+    // v11: 不动 value 原文，只在右侧浮出 "✓ 已复制" 指示
+    if (copied_indicator_) {
+      copied_indicator_->SetVisible(true);
+      InvalidateLayout();
+    }
+    feedback_timer_.Start(
+        FROM_HERE, base::Milliseconds(kCopyFeedbackMs),
+        base::BindOnce(&CopyableFieldRow::ResetFeedback,
+                       weak_factory_.GetWeakPtr()));
+    return true;
+  }
+
+  void OnMouseEntered(const ui::MouseEvent& event) override {
+    SetBackground(views::CreateRoundedRectBackground(kFieldHoverBgColor, 4));
+    SchedulePaint();
+  }
+
+  void OnMouseExited(const ui::MouseEvent& event) override {
+    SetBackground(nullptr);
+    SchedulePaint();
+  }
+
+ private:
+  void ResetFeedback() {
+    if (copied_indicator_) {
+      copied_indicator_->SetVisible(false);
+      InvalidateLayout();
+    }
+  }
+
+  raw_ptr<views::Label> value_label_ = nullptr;
+  raw_ptr<views::Label> copied_indicator_ = nullptr;
+  std::u16string value_text_;
+  base::OneShotTimer feedback_timer_;
+  base::WeakPtrFactory<CopyableFieldRow> weak_factory_{this};
+};
+
+BEGIN_METADATA(CopyableFieldRow)
+END_METADATA

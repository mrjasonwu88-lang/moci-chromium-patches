+constexpr SkColor kTooltipLabelColor   = SkColorSetRGB(0x64, 0x74, 0x8B);  // slate-500
+constexpr SkColor kTooltipValueColor   = SkColorSetRGB(0x0F, 0x17, 0x2A);  // slate-900

+bool MoCiEnvIndicatorView::LoadFromFingerprintConfig() {
+  auto* cmd = base::CommandLine::ForCurrentProcess();
+  if (!cmd || !cmd->HasSwitch("fingerprint-config")) {
+    return false;
+  }
+  auto path = cmd->GetSwitchValuePath("fingerprint-config");
+  if (path.empty()) {
+    return false;
+  }
+  std::string contents;
+  if (!base::ReadFileToString(path, &contents)) {
+    return false;
+  }
+  auto root = base::JSONReader::ReadDict(contents, base::JSON_PARSE_RFC);
+  if (!root) {
+    return false;
+  }
+  auto* env_display = root->FindDict("envDisplay");
+  if (!env_display) {
+    return false;
+  }
+  auto get = [env_display](const char* k) -> std::string {
+    auto* v = env_display->FindString(k);
+    return v ? *v : std::string();
+  };
+  if (auto num = env_display->FindInt("envNumber")) {
+    env_number_ = base::NumberToString(*num);
+  }
+  account_name_ = get("accountName");
+  company_name_ = get("companyName");
+  platform_ = get("platform");
+  platform_site_ = get("platformSite");
+  account_email_ = get("accountEmail");
+  ip_address_ = get("ipAddress");
+  instance_region_ = get("instanceRegion");
+  instance_type_ = get("instanceType");
+  has_data_ = !account_name_.empty() || !ip_address_.empty();
+  if (!has_data_) {
+    return false;
+  }
+
+  BuildRows();
+  BuildTooltipText();
+
+  active_idx_ = 0;
+  if (scroll_container_ && scroll_container_->layer()) {
+    scroll_container_->layer()->SetTransform(gfx::Transform());
+  }
+  StartTickTimer();
+  // v8: 启动 hover polling（chromium OnMouseEntered 在 LocationBar 这层不来）
+  hover_poll_timer_.Start(FROM_HERE, kHoverPollInterval,
+                          base::BindRepeating(&MoCiEnvIndicatorView::PollHover,
+                                              base::Unretained(this)));
+  return true;
+}
+
+void MoCiEnvIndicatorView::BuildRows() {
+  rows_.clear();
+
+  // Row 1: #1 云淘沃尔玛 · Walmart US
+  std::string r1;
+  if (!account_name_.empty()) {
+    r1 = env_number_.empty() ? account_name_
+                             : "#" + env_number_ + " " + account_name_;
+  }
+  if (!platform_.empty()) {
+    if (!r1.empty()) r1 += " · ";
+    r1 += platform_;
+    if (!platform_site_.empty()) r1 += " " + platform_site_;
+  }
+  if (!r1.empty()) {
+    rows_.push_back({std::u16string(), base::UTF8ToUTF16(r1)});
+  }
+
+  // Row 2: 邮箱
+  if (!account_email_.empty()) {
+    rows_.push_back({std::u16string(), base::UTF8ToUTF16(account_email_)});
+  }
+
+  // Row 3: 154.62.163.250 · 美国-弗吉尼亚（宽度基准）
+  std::string r3;
+  if (!ip_address_.empty()) r3 = ip_address_;
+  if (!instance_region_.empty()) {
+    if (!r3.empty()) r3 += " · ";
+    r3 += instance_region_;
+  }
+  if (!r3.empty()) {
+    rows_.push_back({std::u16string(), base::UTF8ToUTF16(r3)});
+  }
+
+  // 用代理行宽度作为整个 bar 的固定宽度
+  if (!rows_.empty()) {
+    const gfx::FontList font = GetMoCiFontList();
+    const InfoRow& proxy_row = rows_.back();
+    int proxy_w = gfx::GetStringWidth(proxy_row.content, font);
+    measured_width_ = proxy_w + kHorizontalPadding * 2 + 4;
+  }
+
+  // wrap 优化：末尾追加 row[0] 副本
+  if (scroll_container_) {
+    scroll_container_->RemoveAllChildViews();
+    row_views_.clear();
+    for (const auto& r : rows_) {
+      row_views_.push_back(scroll_container_->AddChildView(MakeRowView(r)));
+    }
+    if (rows_.size() > 1) {
+      scroll_container_->AddChildView(MakeRowView(rows_[0]));
+    }
+  }
+}
+
+std::unique_ptr<views::View> MoCiEnvIndicatorView::MakeRowView(
+    const InfoRow& info) {
+  const gfx::FontList font = GetMoCiFontList();
+  auto row = std::make_unique<views::View>();
+  auto* layout = row->SetLayoutManager(std::make_unique<views::BoxLayout>(
+      views::BoxLayout::Orientation::kHorizontal, gfx::Insets(), 0));
+  layout->set_cross_axis_alignment(
+      views::BoxLayout::CrossAxisAlignment::kCenter);
+
+  auto content = std::make_unique<views::Label>(
+      info.content, views::Label::CustomFont{font});
+  content->SetEnabledColor(kContentColor);
+  content->SetHorizontalAlignment(gfx::ALIGN_LEFT);
+  content->SetElideBehavior(gfx::ELIDE_TAIL);
+  // 禁用 Label 自动 tooltip（避免和我们的自建 popup tooltip 重叠显示）
+  content->SetHandlesTooltips(false);
+  auto* content_ptr = row->AddChildView(std::move(content));
+  layout->SetFlexForView(content_ptr, 1);
+  row->SetPreferredSize(gfx::Size(0, kRowHeight));
+  return row;
+}
+
+void MoCiEnvIndicatorView::StartTickTimer() {
+  if (!has_data_ || rows_.size() <= 1) {
+    return;
+  }
+  toggle_timer_.Start(FROM_HERE, kToggleInterval,
+                      base::BindRepeating(&MoCiEnvIndicatorView::OnTick,
+                                          base::Unretained(this)));
+}
+
+void MoCiEnvIndicatorView::StopTickTimer() {
+  toggle_timer_.Stop();
+}
+
+void MoCiEnvIndicatorView::OnTick() {
+  if (mouse_inside_) return;
+  if (!scroll_container_ || !scroll_container_->layer() || rows_.empty()) {
+    return;
+  }
+  size_t next = active_idx_ + 1;
+  bool will_wrap = (next >= rows_.size());
+
+  gfx::Transform target;
+  target.Translate(0, -static_cast<int>(next) * kRowHeight);
+
+  {
+    ui::ScopedLayerAnimationSettings settings(
+        scroll_container_->layer()->GetAnimator());
+    settings.SetTransitionDuration(kSlideDuration);
+    settings.SetTweenType(gfx::Tween::EASE_IN_OUT);
+    scroll_container_->layer()->SetTransform(target);
+  }
+  active_idx_ = next;
+
+  if (will_wrap) {
+    base::SequencedTaskRunner::GetCurrentDefault()->PostDelayedTask(
+        FROM_HERE,
+        base::BindOnce(&MoCiEnvIndicatorView::ResetAfterWrap,
+                       weak_factory_.GetWeakPtr()),
+        kSlideDuration + base::Milliseconds(50));
+  }
+}
+
+void MoCiEnvIndicatorView::ResetAfterWrap() {
+  if (!scroll_container_ || !scroll_container_->layer()) {
+    return;
+  }
+  scroll_container_->layer()->GetAnimator()->AbortAllAnimations();
+  scroll_container_->layer()->SetTransform(gfx::Transform());
+  active_idx_ = 0;
+}
+
+void MoCiEnvIndicatorView::OnMouseEntered(const ui::MouseEvent& event) {
+  views::View::OnMouseEntered(event);  // 此回调在 LocationBar 路径不可靠，hover 走 polling
+}
+
+void MoCiEnvIndicatorView::OnMouseExited(const ui::MouseEvent& event) {
+  views::View::OnMouseExited(event);
+}
+
+void MoCiEnvIndicatorView::PollHover() {
+  if (!GetWidget() || !GetVisible()) return;
+  auto* screen = display::Screen::Get();
+  if (!screen) return;
+  gfx::Point cursor = screen->GetCursorScreenPoint();
+  gfx::Rect bar_screen = GetBoundsInScreen();
+  // v10 关键：把 bar+popup 合成"交互区"，含中间的 gap，让 cursor 能从 bar
+  // 安全地滑到 popup 上做复制操作而不会触发 HideTooltip。
+  gfx::Rect interaction_zone = bar_screen;
+  if (tooltip_widget_) {
+    interaction_zone.Union(tooltip_widget_->GetWindowBoundsInScreen());
+  }
+  bool inside = interaction_zone.Contains(cursor);
+  if (inside && !mouse_inside_) {
+    OnEntered();
+  } else if (!inside && mouse_inside_) {
+    OnExited();
+  }
+}
+
+void MoCiEnvIndicatorView::OnEntered() {
+  mouse_inside_ = true;
+  ScheduleShowTooltip();
+}
+
+void MoCiEnvIndicatorView::OnExited() {
+  mouse_inside_ = false;
+  tooltip_show_timer_.Stop();
+  HideTooltip();
+}
+
+void MoCiEnvIndicatorView::BuildTooltipText() {
+  // v9: tooltip 内容直接由 ShowTooltipNow 构造 Label 子视图，
+  // tooltip_text_ 仅作为"有 tooltip 内容"的存在性标记。
+  tooltip_text_ = u"x";  // 非空即可
+}
+
+void MoCiEnvIndicatorView::ScheduleShowTooltip() {
+  if (tooltip_text_.empty()) return;
+  tooltip_show_timer_.Start(FROM_HERE, kTooltipShowDelay,
+                            base::BindOnce(&MoCiEnvIndicatorView::ShowTooltipNow,
+                                           base::Unretained(this)));
+}

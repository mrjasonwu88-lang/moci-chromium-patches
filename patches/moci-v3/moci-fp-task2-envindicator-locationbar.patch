+
+void MoCiEnvIndicatorView::Layout(PassKey) {
+  if (!scroll_container_) {
+    return;
+  }
+  const int content_w = std::max(0, width() - kHorizontalPadding * 2);
+  const size_t n = rows_.size() + (rows_.size() > 1 ? 1 : 0);
+  const int total_h = kRowHeight * static_cast<int>(std::max<size_t>(n, 1));
+  scroll_container_->SetBounds(kHorizontalPadding, kVerticalPadding,
+                               content_w, total_h);
+}
+
+gfx::Size MoCiEnvIndicatorView::CalculatePreferredSize(
+    const views::SizeBounds& available_size) const {
+  if (!has_data_) {
+    return gfx::Size();
+  }
+  int w = measured_width_ > 0 ? measured_width_ : 220;
+  w = std::clamp(w, 160, 320);
+  return gfx::Size(w, kViewHeight);
+}

+MoCiEnvIndicatorView::MoCiEnvIndicatorView() {
+  SetPaintToLayer();
+  // v11d: 让 compositor 自己裁圆角，四个角真透明（否则方形 opaque layer 会
+  // 在圆角外露底色）
+  layer()->SetFillsBoundsOpaquely(false);
+  layer()->SetMasksToBounds(true);
+  layer()->SetRoundedCornerRadius(gfx::RoundedCornersF(kBorderRadius));
+  layer()->SetIsFastRoundedCorner(true);
+  // 只圆角背景，不要边框
+  SetBackground(views::CreateRoundedRectBackground(kBackgroundColor,
+                                                   kBorderRadius));
+
+  // 防御：mouse hover 命中
+  SetCanProcessEventsWithinSubtree(true);
+
+  auto scroll = std::make_unique<views::View>();
+  scroll->SetPaintToLayer();
+  scroll->layer()->SetFillsBoundsOpaquely(false);
+  scroll->SetBackground(views::CreateSolidBackground(kBackgroundColor));
+  scroll->SetLayoutManager(std::make_unique<views::BoxLayout>(
+      views::BoxLayout::Orientation::kVertical, gfx::Insets(), 0));
+  scroll_container_ = AddChildView(std::move(scroll));
+}

+void MoCiEnvIndicatorView::ShowTooltipNow() {
+  if (tooltip_widget_) return;
+  if (!GetWidget()) return;
+  if (tooltip_text_.empty()) return;
+
+  views::Widget::InitParams params(
+      views::Widget::InitParams::CLIENT_OWNS_WIDGET,
+      views::Widget::InitParams::TYPE_TOOLTIP);
+  params.parent = GetWidget()->GetNativeView();
+  // v10: 接收点击（每行复制功能）
+  params.accept_events = true;
+  params.opacity = views::Widget::InitParams::WindowOpacity::kOpaque;
+  params.shadow_type = views::Widget::InitParams::ShadowType::kDrop;
+
+  // v10 紧凑 popup: 深 slate + 1px 描边 + horizontal field rows + click-to-copy
+  auto contents = std::make_unique<views::View>();
+  contents->SetBackground(
+      views::CreateRoundedRectBackground(kTooltipBgColor, 10));
+  contents->SetBorder(views::CreatePaddedBorder(
+      views::CreateRoundedRectBorder(1, 10, kTooltipBorderColor),
+      gfx::Insets::VH(8, 6)));
+  auto* contents_layout =
+      contents->SetLayoutManager(std::make_unique<views::BoxLayout>(
+          views::BoxLayout::Orientation::kVertical, gfx::Insets(), 0));
+  contents_layout->set_cross_axis_alignment(
+      views::BoxLayout::CrossAxisAlignment::kStretch);
+
+  // 先收集所有要展示的行，再一次性添加（以便决定哪些行加 bottom separator）
+  struct Row { std::u16string label; std::u16string value; bool is_group_end; };
+  std::vector<Row> rows;
+
+  // 账号组
+  std::string acc_val = env_number_.empty() ? account_name_
+                          : "#" + env_number_ + " " + account_name_;
+  rows.push_back({u"账号", base::UTF8ToUTF16(acc_val), false});
+  if (!company_name_.empty()) {
+    rows.push_back({u"公司", base::UTF8ToUTF16(company_name_), false});
+  }
+  if (!platform_.empty()) {
+    std::string plat = platform_;
+    if (!platform_site_.empty()) plat += " · " + platform_site_;
+    rows.push_back({u"平台", base::UTF8ToUTF16(plat), false});
+  }
+  if (!account_email_.empty()) {
+    rows.push_back({u"邮箱", base::UTF8ToUTF16(account_email_), false});
+  }
+  if (!rows.empty()) rows.back().is_group_end = true;  // 账号组末尾
+
+  // 代理组
+  rows.push_back({u"代理 IP", base::UTF8ToUTF16(ip_address_), false});
+  if (!instance_region_.empty()) {
+    rows.push_back({u"区域", base::UTF8ToUTF16(instance_region_), false});
+  }
+  if (!instance_type_.empty()) {
+    rows.push_back({u"ISP", base::UTF8ToUTF16(instance_type_), false});
+  }
+
+  // 添加：除最后一行外都加 bottom separator
+  for (size_t i = 0; i < rows.size(); ++i) {
+    bool is_last = (i == rows.size() - 1);
+    contents->AddChildView(std::make_unique<CopyableFieldRow>(
+        rows[i].label, rows[i].value, !is_last));
+    // 账号组末尾后插入加粗分隔（高 8px 让视觉更明显的分组）
+    if (rows[i].is_group_end && !is_last) {
+      auto gap = std::make_unique<views::View>();
+      gap->SetPreferredSize(gfx::Size(0, 6));
+      contents->AddChildView(std::move(gap));
+    }
+  }
+
+  tooltip_widget_ = std::make_unique<views::Widget>();
+  tooltip_widget_->Init(std::move(params));
+  auto* contents_ptr =
+      tooltip_widget_->SetContentsView(std::move(contents));
+
+  // 计算 popup 位置：bar 正下方左对齐，留 6px gap
+  gfx::Size sz = contents_ptr->GetPreferredSize();
+  gfx::Rect bar_screen = GetBoundsInScreen();
+  gfx::Rect bounds(bar_screen.x(), bar_screen.bottom() + 6, sz.width(),
+                   sz.height());
+  tooltip_widget_->SetBounds(bounds);
+  tooltip_widget_->ShowInactive();
+}
+
+void MoCiEnvIndicatorView::HideTooltip() {
+  if (tooltip_widget_) {
+    tooltip_widget_->Close();
+    tooltip_widget_.reset();
+  }
+}

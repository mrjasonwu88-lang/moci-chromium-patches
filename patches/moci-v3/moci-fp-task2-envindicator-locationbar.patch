+constexpr SkColor kBorderColor     = SkColorSetRGB(0xD5, 0xDB, 0xE3);  // 中浅描边可见
+constexpr SkColor kContentColor    = SkColorSetRGB(0x11, 0x18, 0x27);  // 深 graphite
